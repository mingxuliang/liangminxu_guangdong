# ========== 前端（复制为 .env.local 后按需修改）==========
# 知识萃取 BFF：开发时走 Vite 代理到本机 server/index.mjs（见 vite.config.ts /api）
VITE_API_BASE=/api

# 课程创建 · 步骤一～四：Dify（VITE_DIFY_* 见 dify/IMPORT.txt、vite-env.d.ts）
# 步骤五「课件生成」：阿里云市场 iSlide AppCode（VITE_ISLIDE_APPCODE）
# VITE_ISLIDE_APPCODE=

# ========== 后端（与前端同目录 .env / .env.local；node 须能读到项目根下的文件）==========
SERVER_PORT=8787

# ========== 会话存储 ==========
# KE_STORAGE_DRIVER=file | postgres
# 未显式配置时：检测到 DATABASE_URL / PGHOST 等 PostgreSQL 参数则走 postgres，否则回退 file
KE_STORAGE_DRIVER=file

# PostgreSQL（生产建议 DATABASE_URL 或拆分参数）
DATABASE_URL=
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
DATABASE_SSL=0
PGPOOL_MAX=10
PG_CONNECT_TIMEOUT_MS=10000
PG_IDLE_TIMEOUT_MS=30000

# ── Dify 工作流配置（知识萃取服务端）────────────────────────────────
# DIFY_BASE_URL 须以 /v1 结尾
DIFY_BASE_URL=http://127.0.0.1:8088/v1

# Step1「源头锚定」— dify/ke-01-source-anchor.dsl.yml
KE_ANCHOR_API_KEY=

# Step2「分层筛选」— dify/ke-02-layered-filter.dsl.yml
KE_FILTER_API_KEY=

# Step3「结构化提炼」— dify/ke-03-structured-refinement.dsl.yml
KE_REFINE_API_KEY=

# Step4「重新提取单条」— dify/ke-04-reextract-item.dsl.yml
KE_REEXTRACT_API_KEY=

# Step4「批量质量评估」— dify/ke-05-validation-evaluation.dsl.yml
KE_VALIDATION_API_KEY=

# 音频转写精炼（可选）— dify/ke-audio-transcript-refine.dsl.yml
KE_AUDIO_REFINE_API_KEY=

KE_ANCHOR_USER=knowledge-extraction-user

# 音频转写：硅基流动 ASR 优先；失败时可回退 Dify
# https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_ASR_MODEL=FunAudioLLM/SenseVoiceSmall
# KE_SILICONFLOW_ASR_API_KEY=

# Dify audio-to-text（可选，作硅基失败时的回退）
KE_AUDIO_TO_TEXT_API_KEY=

# ========== Sealos 对象存储（S3 兼容，可选）==========
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_BUCKET=
OSS_REGION=us-east-1
OSS_PREFIX=dev
OSS_FORCE_PATH_STYLE=1

# ========== 生产/Devbox：iSlide 代理（仅 Node 托管 out/ 时）==========
# 与 vite 开发代理一致；默认阿里云市场
# ISLIDE_PROXY_TARGET=https://islide.market.alicloudapi.com
