# ========== 前端（复制为 .env.local 后按需修改）==========
# 知识萃取 BFF：走 Vite 代理到本机 server/index.mjs（见 vite.config.ts /api）
VITE_API_BASE=/api

# 课程创建 · 步骤一～四：Dify（VITE_DIFY_* 见 dify/IMPORT.txt、vite-env.d.ts）
# 步骤五「课件生成」：非 Dify，使用阿里云市场 iSlide AppCode
# VITE_ISLIDE_APPCODE=

# ========== 后端（与前端同目录 .env / .env.local；node 须能读到项目根下的文件）==========
SERVER_PORT=8787

# ========== 会话存储 ==========
# KE_STORAGE_DRIVER=file | postgres
# 未显式配置时：检测到 DATABASE_URL / PGHOST 等 PostgreSQL 参数则走 postgres，否则回退 file
KE_STORAGE_DRIVER=file

# PostgreSQL（生产环境建议配置 DATABASE_URL；Sealos Devbox 可直接填写外网连接串）
DATABASE_URL=
# 若不使用 DATABASE_URL，可改填以下拆分参数
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
# Sealos 外网数据库如需 SSL 可设为 1；内网连接通常可保持 0
DATABASE_SSL=0
PGPOOL_MAX=10
PG_CONNECT_TIMEOUT_MS=10000
PG_IDLE_TIMEOUT_MS=30000

# ── Dify 工作流配置 ────────────────────────────────────────────
# DIFY_BASE_URL 须以 /v1 结尾（自建 Dify 改为对应地址）
DIFY_BASE_URL=http://81.70.78.132:8088/v1

# Step1「源头锚定」
# Dify 工作流名称：知识萃取-源头锚定
# 导入文件：dify/ke-01-source-anchor.dsl.yml（提示词未变，可沿用原 Key）
KE_ANCHOR_API_KEY=app-Dmn7y5AKHN0oQlgyU505ncCz

# Step2「分层筛选」★ 已重写提示词（方法论结构 + structured_body），需重新导入后填写新 Key
# Dify 工作流名称：知识萃取-分层筛选
# 导入文件：dify/ke-02-layered-filter.dsl.yml
KE_FILTER_API_KEY=app-e19r6uH3FTKT6jGIEk2AIuDd

# Step3「结构化提炼」★ 已重写提示词（SOP/STAR/工具实内容），需重新导入后填写新 Key
# Dify 工作流名称：知识萃取-结构化提炼
# 导入文件：dify/ke-03-structured-refinement.dsl.yml
KE_REFINE_API_KEY=app-QqYQOJz41fHvdIMpxLwazmd1

# Step4「重新提取单条」★ 已重写提示词（300-600字深度输出），需重新导入后填写新 Key
# Dify 工作流名称：知识萃取-重新提取单条
# 导入文件：dify/ke-04-reextract-item.dsl.yml
KE_REEXTRACT_API_KEY=app-rIiX0eeRolIy0MsnIDMdFvG3

# Step4「批量质量评估」★ 已重写提示词（深度与可操作性评分），需重新导入后填写新 Key
# Dify 工作流名称：知识萃取-批量质量评估
# 导入文件：dify/ke-05-validation-evaluation.dsl.yml
# 评估维度：知识深度与准确性 / 目标对齐性 / 复用与实践价值（各 0-100 分）
KE_VALIDATION_API_KEY=app-YXrmmOAugzYnDIElcSNL190c

# 音频转写精炼工作流（可选，不填则直接用原始转写）
# Dify 工作流名称：知识萃取-音频转写精炼
# 导入文件：dify/ke-audio-transcript-refine.dsl.yml（提示词未变，可沿用原 Key）
KE_AUDIO_REFINE_API_KEY=

KE_ANCHOR_USER=knowledge-extraction-user

# 音频转写：硅基流动 ASR 优先（填 SILICONFLOW_API_KEY），失败时可回退 Dify（需保留 KE_AUDIO_TO_TEXT 等）
# 硅基秘钥：https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-kidmcxzodcbcokrhigmplulrzvejsdzgzbcmdsdpkgjagiuz
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_ASR_MODEL=FunAudioLLM/SenseVoiceSmall
# 与上二选一：KE_SILICONFLOW_ASR_API_KEY=
#
# Dify audio-to-text（可选）：与 ke-01 同应用且开启语音转文字时可与 KE_ANCHOR 相同；作硅基失败时的回退
KE_AUDIO_TO_TEXT_API_KEY=app-w7EHyoTqoFZd4CPaf5SghO4p

# 可选：未配置 KE_ANCHOR_API_KEY 时服务端返回模拟 anchor_package，便于联调 UI

# ========== Sealos 对象存储（S3 兼容，可选）==========
# 配置后上传文件会写入存储桶；音频在转写时会临时下载到本地缓存后立即清理
# 未配置则仍使用 server/uploads/ 本地文件模式
# External：本机开发、外网访问  |  Internal：与 Sealos 同集群内网（见控制台「访问密钥」）
OSS_ENDPOINT=https://objectstorageapi.hzh.sealos.run
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_BUCKET=xook3wzu-guangdong
OSS_REGION=us-east-1
# 对象 key 环境前缀；建议本地/devbox/prod 分开，例如 dev / prod
OSS_PREFIX=dev
# 多数 S3 兼容网关需 path-style；若报错可改为 OSS_FORCE_PATH_STYLE=0 试一次
OSS_FORCE_PATH_STYLE=1
