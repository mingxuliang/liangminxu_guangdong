# 步骤一 Dify（复制为 .env.local 后修改；勿将含真实 Key 的文件提交仓库）

# 方式 A（推荐本地开发）：走 Vite 代理，避免浏览器跨域
# VITE_DIFY_BASE_URL=/dify-api/v1
# DIFY_PROXY_TARGET=http://81.70.78.132:8088

# 方式 B：前端直连自建 Dify（需服务端已配置 CORS，否则浏览器会拦截）
# VITE_DIFY_BASE_URL=http://你的主机:端口/v1

# 应用「API 访问」中的密钥（Bearer）
VITE_DIFY_STEP1_API_KEY=app-xxxxxxxx

# workflow = POST /v1/workflows/run；chat = POST /v1/chat-messages（Agent/Chatflow）
VITE_DIFY_STEP1_APP_MODE=workflow

# 可选：终端用户标识（同一应用内需唯一）
# VITE_DIFY_STEP1_USER_ID=course-create-step1

# 步骤二（与步骤一同一 Base URL）
# VITE_DIFY_STEP2A_API_KEY=app-xxxx
# VITE_DIFY_STEP2B_API_KEY=app-xxxx
# VITE_DIFY_STEP2_USER_ID=course-create-step2

# 步骤三：课程大纲（与步骤一同一 Base URL）
# VITE_DIFY_STEP3_API_KEY=app-xxxx
# VITE_DIFY_STEP3_USER_ID=course-create-step3

# 步骤四：课件 PPT 三级大纲（与步骤一同一 Base URL）
# VITE_DIFY_STEP4_API_KEY=app-xxxx
# VITE_DIFY_STEP4_USER_ID=course-create-step4

# 阿里云市场 iSlide PPT（本地脚本 scripts/call-aliyun-islide-ppt.mjs，勿把 AppCode 打进前端包）
# ALIYUN_ISLIDE_APPCODE=

# 第五步：阿里云市场 iSlide 生成 PPT（前端经 Vite 代理 /islide-api，需重启 dev）
# VITE_ISLIDE_APPCODE=你的AppCode
# ISLIDE_PROXY_TARGET=https://islide.market.alicloudapi.com

# 本地讲义模板生成（ppt-service，默认 http://127.0.0.1:8090）
# PPT_SERVICE_TARGET=http://127.0.0.1:8090
