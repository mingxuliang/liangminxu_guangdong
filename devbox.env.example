# =============================================================================
# Sealos Devbox：无秘钥模板。本机完整变量（含秘钥）见 devbox.env.local（已 gitignore，勿提交）
# =============================================================================
#
# 分两类：
# 1) 运行时（Node 读取）：与 server/index.mjs、dotenv 一致，启动前即可注入。
# 2) 构建时（Vite 嵌入前端）：必须以 VITE_ 开头，须在执行 npm run build 时存在于环境中。
#
# 推荐 Devbox 构建命令（示例）：
#   export $(grep -v '^#' devbox.env.example | xargs)   # 若平台不支持，请逐项粘贴
#   npm ci && npm run build && npm run start:app
#
# 监听端口：平台若注入 PORT，会优先生效（见 server/index.mjs）。
#
# ----- 用户登录 JWT（服务端，生产务必设置强随机串） -----
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
#
# =============================================================================

# ----- 进程与静态站 -----
NODE_ENV=production
SERVE_STATIC=1
# PORT=8787
SERVER_PORT=8787

# ----- 前端 → 同源 /api（构建时写入） -----
VITE_API_BASE=/api

# ----- 课程创建：Dify OpenAPI 根（须以 /v1 结尾；构建时写入） -----
# 示例：自建 Dify http://your-dify-host:8088/v1
VITE_DIFY_BASE_URL=http://your-dify-host:8088/v1
VITE_DIFY_STEP1_API_KEY=
VITE_DIFY_STEP1_APP_MODE=workflow
# VITE_DIFY_STEP1_USER_ID=course-create-step1
VITE_DIFY_STEP2A_API_KEY=
VITE_DIFY_STEP2B_API_KEY=
# VITE_DIFY_STEP2_USER_ID=course-create-step2
VITE_DIFY_STEP3_API_KEY=
# VITE_DIFY_STEP3_USER_ID=course-create-step3
# VITE_DIFY_STEP3_TIMEOUT_MS=120000
VITE_DIFY_STEP4_API_KEY=
# VITE_DIFY_STEP4_USER_ID=course-create-step4

# ----- 课程创建 · 第五步 iSlide（构建时写入 AppCode；请求走同源 /islide-api，由 Node 代理） -----
VITE_ISLIDE_APPCODE=
# 可选，默认 https://islide.market.alicloudapi.com
# ISLIDE_PROXY_TARGET=https://islide.market.alicloudapi.com

# ----- 知识萃取 BFF：PostgreSQL -----
KE_STORAGE_DRIVER=postgres
DATABASE_SSL=0
# 二选一：DATABASE_URL 或下列拆分项（与 server/lib/db.mjs 一致）
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
PGHOST=dify-db-postgresql.ns-xook3wzu.svc
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=
PGPOOL_MAX=10
PG_CONNECT_TIMEOUT_MS=10000
PG_IDLE_TIMEOUT_MS=30000

# ----- Dify（服务端工作流，知识萃取 Step1～4） -----
# 须以 /v1 结尾
DIFY_BASE_URL=http://your-dify-host:8088/v1
KE_ANCHOR_API_KEY=
KE_FILTER_API_KEY=
KE_REFINE_API_KEY=
KE_REEXTRACT_API_KEY=
KE_VALIDATION_API_KEY=
KE_AUDIO_REFINE_API_KEY=
KE_AUDIO_TO_TEXT_API_KEY=
KE_ANCHOR_USER=knowledge-extraction-user
# KE_ANCHOR_TIMEOUT_MS=180000

# ----- ASR（硅基优先，否则 Dify） -----
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_ASR_MODEL=FunAudioLLM/SenseVoiceSmall
# KE_SILICONFLOW_ASR_API_KEY=

# ----- Sealos 对象存储（S3 兼容） -----
OSS_ENDPOINT=http://object-storage.objectstorage-system.svc
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_BUCKET=
OSS_REGION=us-east-1
OSS_PREFIX=prod
OSS_FORCE_PATH_STYLE=1
